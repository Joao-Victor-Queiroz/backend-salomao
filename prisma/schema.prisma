// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  COORDENADOR_GERAL
  FORMADOR
  COORDENADOR_FREQUENCIA
  COORDENADOR_CAIXINHA
  ANIMADOR_FREQUENCIA
  ANIMADOR_CAIXINHA
  ANIMADOR
}

enum StatusFrequencia {
  P
  FNJ
  FJ
}

enum DescricaoFrequenciaAnimador {
  FORMACAO
  ENCONTRO
}

model Animador {
  id    String   @id @default(uuid())
  nomeAnimador String
  email String @unique
  password String
  cargo Cargo @default(ANIMADOR)
  frequencias FrequenciaAnimador[]
  grupoAnimadorId String?
  grupoAnimador Grupo? @relation("GrupoFrequencia", fields: [grupoAnimadorId], references: [id])
  grupoCrismandoId String?
  grupoCrismando Grupo? @relation("GrupoCrismando", fields: [grupoCrismandoId], references: [id])
  sessions RefreshToken[]
}

model Grupo {
  id String @id @default(uuid())
  nomeGrupo String
  animadoresFrequencia Animador[] @relation("GrupoFrequencia")
  animadoresMinisterio Animador[] @relation("GrupoCrismando")
  crismandos Crismando[]
}

model Crismando {
  id String @id @default(uuid())
  nomeCrismando String
  cpf String
  idade Int 
  dataNascimento DateTime @db.Date
  cidadeNascimento String
  estadoNascimento String
  endereco String
  numEndereco String
  complemento String
  bairro String
  cep String
  telefoneCrismando String
  nomePai String
  nomeMae String
  telefonePai String
  telefoneMae String
  batizado String
  primeiraEucaristia String
  justificativa String
  ativo Boolean @default(true)
  frequencias Frequencia[]
  caixinhas Caixinha[]
  grupoId String?
  grupo Grupo? @relation(fields: [grupoId], references: [id], onDelete: SetNull)
}

model Frequencia {
  id String @id @default(uuid())
  crismandoId String
  crismando Crismando? @relation(fields: [crismandoId], references: [id], onDelete: Cascade)
  status StatusFrequencia
  dataFrequencia DateTime @db.Date
  justificativa String?

  @@unique([crismandoId, dataFrequencia])
}

model FrequenciaAnimador {
  id String @id @default(uuid())
  animadorId String
  animador Animador? @relation(fields: [animadorId], references: [id], onDelete: Cascade)
  tipo DescricaoFrequenciaAnimador
  status StatusFrequencia
  dataFrequencia DateTime @db.Date
  justificativa String?

  @@unique([animadorId, dataFrequencia, tipo])
}

model Caixinha {
  id String @id @default(uuid())
  crismandoId String
  crismando Crismando? @relation(fields: [crismandoId], references: [id], onDelete: Cascade)
  valorPago Float
  dataPagamento DateTime @db.Date
}

model RefreshToken {
  id String @id @default(uuid())
  token String
  animadorId String
  animador Animador @relation(fields: [animadorId], references: [id])
  createdAt DateTime @default(now())
  expiresAt DateTime 
  revokedAt DateTime?
  userAgent String?
  ipAdress String?
}